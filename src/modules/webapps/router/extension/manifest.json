{
  "manifest_version": 3,
  "name": "N.E.S.T. WebApp Router",
  "version": "0.2.0",
  "description": "Reutiliza ventanas WebApp existentes para enlaces administrados por N.E.S.T.",
  "minimum_chrome_version": "120",
  "permissions": [
    "storage"
  ],
  "host_permissions": [],
  "background": {
    "service_worker": "background.js",
    "type": "module"
  },
  "action": {
    "default_title": "N.E.S.T. WebApp Router",
    "default_popup": "popup.html"
  }
}
